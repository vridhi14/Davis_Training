# Function to check palindrome
def is_palindrome(num):
    original = num
    reversed_num = 0

    while num > 0:
        digit = num % 10
        reversed_num = reversed_num * 10 + digit
        num = num // 10

    # Compare original and reversed
    if original == reversed_num:
        return "Palindrome"
    else:
        return "Not Palindrome"

# Input
num = 121

# Output
print(is_palindrome(num))
