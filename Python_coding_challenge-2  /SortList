# Function to sort list (Bubble Sort)
def sort_list(lst):
    n = len(lst)
    
    for i in range(n):
        for j in range(0, n-i-1):
            if lst[j] > lst[j+1]:
                # swap
                lst[j], lst[j+1] = lst[j+1], lst[j]
    
    return lst

# Input
numbers = [3,1,2]

# Output
print(sort_list(numbers))
