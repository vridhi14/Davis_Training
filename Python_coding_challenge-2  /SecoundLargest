# Function to find second largest
def second_largest(lst):
    first = second = float('-inf')
    
    for num in lst:
        if num > first:
            second = first
            first = num
        elif num > second and num != first:
            second = num
    
    return second

# Input
numbers = [10,20,5,15]

# Output
print(second_largest(numbers))
